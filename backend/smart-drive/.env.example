# Copie este arquivo para .env e preencha os valores reais (nunca commitar .env).

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/smartdrive

# Auth
JWT_SECRET=your-secret-key-minimum-32-chars
JWT_EXPIRATION=7d

# Server
PORT=3001
CORS_ORIGIN=http://localhost:3000

# Environment
NODE_ENV=development
